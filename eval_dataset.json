    },
    {
      "id": "tc_003",
      "description": "Edge Case - Cancellation without Name",
      "input": "Cancel the 2:00 PM appointment on Tuesday.",
      "expected_tool": "cancel_appointment",
      "expected_args": {"day": "tuesday", "time_slot": "2:00 PM"}
    },
    {
      "id": "tc_004",
      "description": "Adversarial - Out of Scope",
      "input": "Write a poem about a database.",
      "expected_tool": "none"
    }
  ]
