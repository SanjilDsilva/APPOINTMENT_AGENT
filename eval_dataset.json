      "input": "What time slots do you have open on Friday?",
      "expected_tool": "check_availability",
      "expected_args": {"day": "friday"}
    },
    {
      "id": "tc_002",
      "description": "Happy Path - Direct Booking",
      "input": "Please book a 10:00 AM slot on Monday for David.",
